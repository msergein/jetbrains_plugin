            val document = createMockDocument(fileContent)

            val block = createMockBlock(startLine = 1, endLine = 1, fileContent = fileContent)

            val result =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(block),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 0),
                )
            result shouldBe true
        }

        @Test
        fun `handles multiline deletion (fewer lines in modified)`() {
            // Original has 5 lines, modified has 3 lines
            val originalCode = "start\nold1\nold2\nold3\nend"
            val modifiedCode = "start\nnew\nend"
            // Shared prefix: 1 line, shared suffix: 1 line
            // foundLine=0, changeStart=1, changeEnd=0+5-1=4
            val fileContent = originalCode
            val document = createMockDocument(fileContent)

            val block = createMockBlock(startLine = 3, endLine = 3, fileContent = fileContent)

            val result =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(block),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 0),
                )
            result shouldBe true
        }

        @Test
        fun `real world example - function body change`() {
            val originalCode =
                """
                fun calculate(x: Int): Int {
                    val result = x * 2
                    return result
                }
                """.trimIndent()

            val modifiedCode =
                """
                fun calculate(x: Int): Int {
                    val result = x * 3 + 1
                    return result
                }
                """.trimIndent()

            // Shared prefix: 1 line (function signature)
            // Shared suffix: 2 lines (return result, closing brace)
            // foundLine=50, changeStart=51, changeEnd=50+4-2=52
            val fileContent = createFileContent(originalCode, startAtLine = 50)
            val document = createMockDocument(fileContent)

            // Block on line 51 (the changed line) - should overlap
            val blockOverlap = createMockBlock(startLine = 51, endLine = 51, fileContent = fileContent)
            val resultOverlap =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(blockOverlap),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 50),
                )
            resultOverlap shouldBe true

            // Block on line 53 (return statement) - should not overlap
            val blockNoOverlap = createMockBlock(startLine = 53, endLine = 53, fileContent = fileContent)
            val resultNoOverlap =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(blockNoOverlap),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 50),
                )
            resultNoOverlap shouldBe false
        }

        @Test
        fun `real world example - adding import at top of file`() {
            val originalCode =
                """
                import foo.Bar
                import foo.Baz

                class MyClass {
                """.trimIndent()

            val modifiedCode =
                """
                import foo.Bar
                import foo.Baz
                import foo.Qux

                class MyClass {
                """.trimIndent()

            // Shared prefix: 2 lines
            // Shared suffix: 2 lines (empty line, class declaration)
            // foundLine=0, changeStart=2, changeEnd=0+4-2=2
            val fileContent = originalCode
            val document = createMockDocument(fileContent)

            // Block on lines 10-15 (somewhere in class body) - should not overlap
            val block = createMockBlock(startLine = 10, endLine = 15, fileContent = fileContent)

            val result =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(block),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 0),
                )
            result shouldBe false
        }

        @Test
        fun `returns true when originalCode not found in file content`() {
            val originalCode = "code that doesn't exist"
            val modifiedCode = "new code"
            val fileContent = "completely different content"
            val document = createMockDocument(fileContent)

            val block = createMockBlock(startLine = 0, endLine = 0, fileContent = fileContent)

            val result =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(block),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 0),
                )

            // Should be conservative and return true
            result shouldBe true
        }

        @Test
        fun `returns true when block has invalid range marker`() {
            val originalCode = "line1\nline2\nline3"
            val modifiedCode = "line1\nmodified\nline3"
            val fileContent = originalCode
            val document = createMockDocument(fileContent)

            // Create a block with an invalid range marker
            val block = mock(AppliedCodeBlock::class.java)
            val rangeMarker = mock(RangeMarker::class.java)
            `when`(rangeMarker.isValid).thenReturn(false)
            `when`(block.rangeMarker).thenReturn(rangeMarker)

            val result =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(block),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 0),
                )

            // Should be conservative and return true
            result shouldBe true
        }

        @Test
        fun `returns true when block has null range marker`() {
            val originalCode = "line1\nline2\nline3"
            val modifiedCode = "line1\nmodified\nline3"
            val fileContent = originalCode
            val document = createMockDocument(fileContent)

            // Create a block with a null range marker
            val block = mock(AppliedCodeBlock::class.java)
            `when`(block.rangeMarker).thenReturn(null)

            val result =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(block),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 0),
                )

            // Should be conservative and return true
            result shouldBe true
        }
    }
}

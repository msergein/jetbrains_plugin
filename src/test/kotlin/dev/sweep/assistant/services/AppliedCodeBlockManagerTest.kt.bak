            val originalCode = "same\nold1\nold2"
            val modifiedCode = "same\nnew1\nnew2\nnew3"
            // foundLine=0, changeStart=1, changeEnd=0+3-0=3
            val fileContent = originalCode
            val document = createMockDocument(fileContent)

            val block = createMockBlock(startLine = 2, endLine = 2, fileContent = fileContent)

            val result =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(block),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 0),
                )
            result shouldBe true
        }

        @Test
        fun `handles completely different code (no shared lines)`() {
            // No shared prefix or suffix
            val originalCode = "aaa\nbbb"
            val modifiedCode = "xxx\nyyy\nzzz"
            // foundLine=0, changeStart=0, changeEnd=2
            // Add extra lines so block can be on lines 3-5
            val fileContent = originalCode + "\nccc\nddd\neee\nfff"
            val document = createMockDocument(fileContent)

            val block = createMockBlock(startLine = 3, endLine = 5, fileContent = fileContent)

            val result =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(block),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 0),
                )
            result shouldBe false
        }

        @Test
        fun `handles identical code (all lines shared)`() {
            // All lines are shared prefix, changeStart = changeEnd = foundLine + numLines
            val originalCode = "line1\nline2\nline3"
            val modifiedCode = "line1\nline2\nline3"
            // foundLine=0, prefix=3, suffix=0, changeStart=3, changeEnd=3
            val fileContent = originalCode
            val document = createMockDocument(fileContent)

            // Block 0-2 doesn't overlap with change at line 3
            val block = createMockBlock(startLine = 0, endLine = 2, fileContent = fileContent)

            val result =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(block),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 0),
                )

            result shouldBe false
        }

        @Test
        fun `handles single line change in middle of file`() {
            // 5 lines, only middle line (index 2) changes
            val originalCode = "a\nb\nOLD\nd\ne"
            val modifiedCode = "a\nb\nNEW\nd\ne"
            // foundLine=100, prefix=2, suffix=2, changeStart=102, changeEnd=103
            val fileContent = createFileContent(originalCode, startAtLine = 100)
            val document = createMockDocument(fileContent)

            val block = createMockBlock(startLine = 102, endLine = 102, fileContent = fileContent)

            val result =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(block),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 100),
                )
            result shouldBe true
        }

        @Test
        fun `block one line before change region does not overlap or border`() {
            val originalCode = "line1\nline2\nline3"
            val modifiedCode = "line1\nmodified\nline3"
            // Change is on line 11 (foundLine=10, prefix=1, changeStart=11, changeEnd=12)
            val fileContent = createFileContent(originalCode, startAtLine = 10)
            val document = createMockDocument(fileContent)

            // Block ends at line 9, one line before change starts - no border
            val block = createMockBlock(startLine = 5, endLine = 9, fileContent = fileContent)

            val result =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(block),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 10),
                )
            // Block ends at 9, change starts at 11 - they don't border
            result shouldBe false
        }

        @Test
        fun `block exactly one line after change region does not overlap`() {
            val originalCode = "line1\nline2\nline3"
            val modifiedCode = "line1\nmodified\nline3"
            // foundLine=0, prefix=1, suffix=1, changeStart=1, changeEnd=2
            // Add extra lines so block can be on lines 3-5
            val fileContent = originalCode + "\nline4\nline5\nline6"
            val document = createMockDocument(fileContent)

            // Block starts at line 3, one line after change ends
            val block = createMockBlock(startLine = 3, endLine = 5, fileContent = fileContent)

            val result =
                shouldRejectConflictingBlocksForFile(
                    currentAppliedCodeBlocks = listOf(block),
                    originalCode = originalCode,
                    modifiedCode = modifiedCode,
                    currentFileContent = fileContent,
                    document = document,
                    project = null,
                    testFoundOffset = getLineStartOffset(fileContent, 0),
                )
            // Block starts at 3, change ends at 2 - they don't border
            result shouldBe false
        }

